generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VisitorRequest {
  id              Int      @id @default(autoincrement())
  requestId       String   @unique @default(uuid())
  name            String
  citizenshipNo   String
  organization    String
  purpose         String
  personToMeet    String
  visitDate       DateTime
  phone           String
  email           String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CHECKED_IN, COMPLETED
  documentUrl     String?
  visitTime       String?
  qrCode          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
